{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["dom", "es6"],
    "allowJs": true,
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "*": ["./node_modules/*", "./src/types/*"]
    }
  },
  "ts-node": {
    "files": true
  },
  "include": ["src/**/*", "**/*.ts"]
}
